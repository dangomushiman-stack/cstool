<Window x:Class="CInterpreterWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="C Language Interpreter &amp; Snapshot Viewer" Height="760" Width="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="1.3*"/>
        </Grid.ColumnDefinitions>

        <!-- Left pane -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     x:Name="CodeEditor"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     FontFamily="Consolas"
                     FontSize="14"
                     Padding="5"
                     VerticalScrollBarVisibility="Auto" />

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          Background="LightGray"/>

            <TextBox Grid.Row="2"
                     x:Name="ConsoleOutput"
                     IsReadOnly="True"
                     Background="#1E1E1E"
                     Foreground="#D4D4D4"
                     FontFamily="Consolas"
                     Padding="5"
                     VerticalScrollBarVisibility="Auto"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                <Button x:Name="RunButton"
                        Content="Run Code"
                        Width="140"
                        Height="36"
                        Margin="0,0,8,0"
                        Background="#007ACC"
                        Foreground="White"
                        FontSize="14"
                        FontWeight="Bold"
                        Click="RunButton_Click"/>

                <Button x:Name="PrevStepButton"
                        Content="◀ Prev"
                        Width="90"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="PrevStepButton_Click"/>

                <Button x:Name="NextStepButton"
                        Content="Next ▶"
                        Width="90"
                        Height="36"
                        Margin="0,0,8,0"
                        Click="NextStepButton_Click"/>

                <Button x:Name="RunToBreakpointButton"
                        Content="Run To Breakpoint"
                        Width="150"
                        Height="36"
                        Click="RunToBreakpointButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Breakpoints (step numbers):"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <TextBox x:Name="BreakpointTextBox"
                         Width="220"
                         Height="28"/>
                <TextBlock x:Name="SnapshotInfoText"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Text="No snapshot selected"/>
            </StackPanel>
        </Grid>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      Background="LightGray"/>

        <!-- Right pane -->
        <Grid Grid.Column="2" Background="#F3F3F3">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.05*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="1.1*"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="1.25*"/>
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="履歴ビュー / Snapshots" Margin="5">
                <ListBox x:Name="SnapshotListBox"
                         Margin="5"
                         SelectionChanged="SnapshotListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Step}" Width="45"/>
                                <TextBlock Text=" | " />
                                <TextBlock Text="{Binding Event}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>

            <GridSplitter Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          Background="LightGray"/>

            <GroupBox Grid.Row="2" Header="現在の生存変数ビュー" Margin="5">
                <DataGrid x:Name="MemoryGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Addr" Binding="{Binding Address}" Width="70"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                        <DataGridTextColumn Header="Variable" Binding="{Binding VariableName}" Width="100"/>
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GridSplitter Grid.Row="3"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          Background="LightGray"/>

            <GroupBox Grid.Row="4" Header="Byte Memory Viewer" Margin="5">
                <DataGrid x:Name="ByteMemoryGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Addr" Binding="{Binding Address}" Width="70"/>
                        <DataGridTextColumn Header="Hex" Binding="{Binding HexValue}" Width="60"/>
                        <DataGridTextColumn Header="Dec" Binding="{Binding DecimalValue}" Width="60"/>
                        <DataGridTextColumn Header="Char" Binding="{Binding CharValue}" Width="60"/>
                        <DataGridTextColumn Header="Note" Binding="{Binding Note}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>